    "# 5. THE RUNNING ENGINE EXECUTOR\n",
    "start = time.perf_counter()\n",
    "\n",
    "step = 0\n",
    "print(\"\\n Core Engine ready. Starting training loops with Automatic Mixed Precision...\")\n",
    "\n",
    "while step < max_steps:\n",
    "    for x, y, pos_ids, mask in dataloader:\n",
    "        if step >= max_steps:\n",
    "            break\n",
    "            \n",
    "        x, y = x.to(device), y.to(device)\n",
    "        mask = mask.to(device)\n",
    "        pos_ids = pos_ids.to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        with torch.autocast(device_type='cuda', dtype=torch.float16):\n",
    "            logits, loss = model(x, custom_mask=mask, pos_ids=pos_ids, targets=y)\n",
    "            \n",
    "        scaler.scale(loss).backward()\n",
    "        scaler.unscale_(optimizer)\n",
    "        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "        \n",
    "        scaler.step(optimizer)\n",
    "        scaler.update()\n",
    "        wandb.log({\n",
    "            \"step\": step,\n",
    "            \"train_loss\": loss.item(),\n",
    "            \"active_vocab_size\": model.config.vocab_size,\n",
    "            \"learning_rate\": optimizer.param_groups[0][\"lr\"]\n",
    "        }) \n",
    "        if step % 500 == 0:\n",
    "            print(f\"Step {step:05d} | Loss: {loss.item():.4f} | Active Matrix Width: {model.config.vocab_size}\")\n",
    "        step += 1\n",
    "\n",
    "end = time.perf_counter()\n",
    "execution_time = end - start\n",
    "\n",
    "print(f\"Training took {execution_time:.0f} seconds to run.\")\n"
   ]
